# Copy to .env and edit (`cp .env.example .env`). .env is gitignored —
# machine-specific paths and private keys go there, never in code.
# Real environment variables override .env (JOI_MODE=gaming python main.py).

# normal | gaming (gaming = CPU-only inference, GPU free for the game)
#JOI_MODE=normal

# agent | plain (plain = no tools, direct ollama.chat fallback)
#JOI_BACKEND=agent

# Ollama model tag
#JOI_MODEL=qwen3:8b

# Force Whisper language (es) if Spanglish drops words; empty = autodetect
#JOI_WHISPER_LANGUAGE=

# Absolute path to a Piper voice .onnx, if not the default under models/tts/
#JOI_VOICE=

# Future capability API keys go here, e.g.:
#SOME_SERVICE_API_KEY=
